let tasksCache = [];
let taskFilter = 'todos';

async function loadTasks() {
  setSyncStatus('tasks-sync-dot','tasks-sync-txt','loading','Carregando...');
  const rows = await sb.get('tasks', 'order=created_at.desc&select=*');
  if(rows === null) {
    setSyncStatus('tasks-sync-dot','tasks-sync-txt','err','Sem conexão');
    document.getElementById('tasks-list').innerHTML =
      '<div class="empty"><div class="empty-icon">📡</div><div class="empty-txt">Sem conexão com o servidor.<br>Verifique sua internet.</div></div>';
    return;
  }
  tasksCache = rows;
  setSyncStatus('tasks-sync-dot','tasks-sync-txt','ok','Sincronizado');
  renderTasks();
}

function renderTasks() {
  const c = document.getElementById('tasks-list');
  let tasks = [...tasksCache];

  if(taskFilter === 'Pendente') tasks = tasks.filter(t=>t.status!=='Feito');
  else if(taskFilter === 'Feito') tasks = tasks.filter(t=>t.status==='Feito');
  else if(taskFilter === 'Alta') tasks = tasks.filter(t=>t.priority==='Alta');
  else if(taskFilter === 'Média') tasks = tasks.filter(t=>t.priority==='Média');

  // Sort: pendentes primeiro, depois por prioridade
  const priOrd = {Alta:0,Média:1,Baixa:2};
  tasks.sort((a,b)=>{
    if(a.status==='Feito' && b.status!=='Feito') return 1;
    if(a.status!=='Feito' && b.status==='Feito') return -1;
    return (priOrd[a.priority]??1) - (priOrd[b.priority]??1);
  });

  if(!tasks.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">✅</div><div class="empty-txt">Nenhuma tarefa aqui.<br>Toque em ＋ para adicionar.</div></div>';
    return;
  }

  c.innerHTML = '';
  tasks.forEach(t => {
    const done = t.status === 'Feito';
    const priClass = {Alta:'pri-alta',Média:'pri-media',Baixa:'pri-baixa'}[t.priority] || 'pri-media';
    const today = new Date().toISOString().slice(0,10);
    const overdue = t.due_date && t.due_date < today && !done;

    const div = document.createElement('div');
    div.className = 'task-item' + (done?' done':'');
    div.innerHTML = `
      <div class="pri-dot ${priClass}"></div>
      <div class="task-check">${done?'✓':''}</div>
      <div class="task-body">
        <div class="task-title">${t.title}</div>
        <div class="task-meta">
          <span class="task-cat">${t.category||'Geral'}</span>
          ${t.due_date?`<span class="task-due${overdue?' overdue':''}">${overdue?'⚠ ':''} ${fmtDate(t.due_date)}</span>`:''}
        </div>
        ${t.notes?`<div class="task-notes">${t.notes}</div>`:''}
      </div>
      <div style="display:flex;flex-direction:column;gap:4px;flex-shrink:0">
        <button class="btn btn-ghost btn-sm" onclick="editTask('${t.id}')">✏️</button>
        <button class="btn btn-ghost btn-sm" onclick="deleteTask('${t.id}')">🗑</button>
      </div>`;
    div.querySelector('.task-check').addEventListener('click', e => { e.stopPropagation(); toggleTask(t.id, t.status); });
    c.appendChild(div);
  });
}

async function toggleTask(id, currentStatus) {
  const newStatus = currentStatus === 'Feito' ? 'Pendente' : 'Feito';
  const t = tasksCache.find(x=>x.id===id);
  if(t) t.status = newStatus;
  renderTasks();
  await sb.patch('tasks', {status:newStatus, updated_at:new Date().toISOString()}, `id=eq.${id}`);
  setSyncStatus('tasks-sync-dot','tasks-sync-txt','ok','Salvo ✓');
  showToast(newStatus==='Feito' ? '✅ Tarefa concluída!' : '↩ Reaberta');
}

function filterTasks(f, btn) {
  taskFilter = f;
  document.querySelectorAll('.task-filter').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderTasks();
}

function fmtDate(d) {
  if(!d) return '';
  const [y,m,day] = d.split('-');
  return `${day}/${m}`;
}

// Task modal
let editingTaskId = null;

function openTaskModal(id) {
  editingTaskId = id || null;
  document.getElementById('task-modal-title').textContent = id ? 'Editar Tarefa' : 'Nova Tarefa';
  if(id) {
    const t = tasksCache.find(x=>x.id===id);
    if(t) {
      document.getElementById('tm-title').value = t.title;
      document.getElementById('tm-cat').value = t.category||'Geral';
      document.getElementById('tm-pri').value = t.priority||'Média';
      document.getElementById('tm-due').value = t.due_date||'';
      document.getElementById('tm-status').value = t.status||'Pendente';
      document.getElementById('tm-notes').value = t.notes||'';
    }
  } else {
    document.getElementById('tm-title').value = '';
    document.getElementById('tm-cat').value = 'Geral';
    document.getElementById('tm-pri').value = 'Média';
    document.getElementById('tm-due').value = '';
    document.getElementById('tm-status').value = 'Pendente';
    document.getElementById('tm-notes').value = '';
  }
  document.getElementById('task-modal').classList.add('open');
}

function closeTaskModal(e) {
  if(!e || e.target.id==='task-modal' || e.currentTarget.tagName==='BUTTON')
    document.getElementById('task-modal').classList.remove('open');
}

async function saveTask() {
  const title = document.getElementById('tm-title').value.trim();
  if(!title) { showToast('⚠️ Digite o nome da tarefa'); return; }
  const data = {
    title,
    category: document.getElementById('tm-cat').value,
    priority: document.getElementById('tm-pri').value,
    due_date: document.getElementById('tm-due').value || null,
    status: document.getElementById('tm-status').value,
    notes: document.getElementById('tm-notes').value.trim() || null,
    updated_at: new Date().toISOString()
  };
  closeTaskModal();
  setSyncStatus('tasks-sync-dot','tasks-sync-txt','loading','Salvando...');

  if(editingTaskId) {
    await sb.patch('tasks', data, `id=eq.${editingTaskId}`);
    const idx = tasksCache.findIndex(t=>t.id===editingTaskId);
    if(idx>=0) tasksCache[idx] = {...tasksCache[idx], ...data};
    showToast('✏️ Tarefa atualizada');
  } else {
    const res = await sb.post('tasks', data);
    if(res && res[0]) tasksCache.unshift(res[0]);
    showToast('✅ Tarefa adicionada');
  }
  setSyncStatus('tasks-sync-dot','tasks-sync-txt','ok','Salvo ✓');
  renderTasks();
}

async function editTask(id) { openTaskModal(id); }

async function deleteTask(id) {
  if(!confirm('Apagar esta tarefa?')) return;
  tasksCache = tasksCache.filter(t=>t.id!==id);
  renderTasks();
  await sb.del('tasks', `id=eq.${id}`);
  showToast('🗑 Tarefa removida');
}

