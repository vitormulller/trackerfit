function buildDashboard() {
  const latest = weeklyData[weeklyData.length-1] || {};
  const prev   = weeklyData[weeklyData.length-2] || {};

  setValue('stat-peso', latest.peso ? latest.peso+'kg' : '–');
  setValue('stat-cintura', latest.cintura ? latest.cintura+'cm' : '–');
  setValue('stat-treinos', latest.treinos ?? '–');
  setValue('stat-energia', latest.energia ? '★'.repeat(latest.energia)+'☆'.repeat(5-latest.energia) : '–');

  setDelta('stat-peso-d', latest.peso, prev.peso, true);
  setDelta('stat-cintura-d', latest.cintura, prev.cintura, true);

  const pct = Math.round((currentWeek/PLAN_WEEKS)*100);
  document.getElementById('prog-week').textContent = currentWeek;
  document.getElementById('prog-pct').textContent = pct+'%';
  document.getElementById('prog-fill').style.width = pct+'%';

  const phase = currentWeek<=4 ? ['Fase Base','Adaptação, técnica e consistência','Sem 1–4','#2a6e2a']
              : currentWeek<=8 ? ['Fase Progressão','Aumentar carga e densidade','Sem 5–8','#1a5c9e']
              :                  ['Fase Consolidação','Refino, aderência e reduzir medidas','Sem 9–12','#7c3aed'];
  document.getElementById('phase-name').textContent = phase[0];
  document.getElementById('phase-desc').textContent = phase[1];
  document.getElementById('phase-weeks').textContent = phase[2];
  document.getElementById('phase-banner').style.background = phase[3];

  document.getElementById('modal-week-num').textContent = currentWeek;
}

function setValue(id, v) { document.getElementById(id).textContent = v; }

function setDelta(id, curr, prev, invertGood) {
  const el = document.getElementById(id);
  if (!curr || !prev) { el.textContent = ''; return; }
  const d = (curr - prev).toFixed(1);
  const good = invertGood ? d < 0 : d > 0;
  el.textContent = (d>0?'+':'')+d+' vs semana ant.';
  el.className = 'stat-delta ' + (good ? 'delta-good' : 'delta-bad');
}

