function buildMeals() {
  const meals = currentDietDay===0 ? MEALS_WEEKDAY : MEALS_WEEKEND;
  const checked = dietChecked[todayKey()] || {};
  const c = document.getElementById('meal-list');
  c.innerHTML = '';

  let totalK=0,totalP=0,totalC=0,totalG=0;
  meals.forEach(m => {
    if (checked[m.id]) { totalK+=m.kcal; totalP+=m.prot; totalC+=m.carbo; totalG+=m.gord; }
  });

  // Update summary
  const sd = document.getElementById('diet-summary');
  const items = sd.querySelectorAll('.diet-sum-val');
  items[0].textContent = totalK;
  items[1].textContent = totalP+'g';
  items[2].textContent = totalC+'g';
  items[3].textContent = totalG+'g';
  document.getElementById('kcal-fill').style.width = Math.min(100, Math.round(totalK/2192*100))+'%';

  meals.forEach(m => {
    const done = !!checked[m.id];
    const card = document.createElement('div');
    card.className = 'meal-card'+(done?' done':'');
    card.innerHTML = `
      <div class="meal-header" onclick="toggleMeal(this,'${m.id}')">
        <span class="meal-icon">${m.icon}</span>
        <div class="meal-info">
          <div class="meal-name">${m.name}</div>
          <div class="meal-time">${m.time}</div>
        </div>
        <span class="meal-kcal">${m.kcal} kcal</span>
        <div class="meal-check">${done?'✓':''}</div>
      </div>
      <div class="meal-body">
        <div class="meal-food">${m.food}</div>
        <div class="meal-macros">
          <span class="macro-chip">🥩 ${m.prot}g prot</span>
          <span class="macro-chip">🍚 ${m.carbo}g carbo</span>
          <span class="macro-chip">🥑 ${m.gord}g gord</span>
        </div>
        <button class="btn ${done?'btn-ghost':'btn-primary'} btn-sm" style="margin-top:10px;width:100%" onclick="toggleMealDone('${m.id}')">
          ${done?'↩ Desmarcar':'✓ Marcar como feito'}
        </button>
      </div>`;
    c.appendChild(card);
  });
}

function toggleMeal(header, id) {
  const card = header.closest('.meal-card');
  const wasOpen = card.classList.contains('open');
  document.querySelectorAll('.meal-card.open').forEach(x=>x.classList.remove('open'));
  if(!wasOpen) card.classList.add('open');
}

function toggleMealDone(id) {
  const today = todayKey();
  if (!dietChecked[today]) dietChecked[today] = {};
  dietChecked[today][id] = !dietChecked[today][id];
  save('tf_diet', dietChecked);
  buildMeals();
}

