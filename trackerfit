<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>TrackFit</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f4f3ee;--surface:#ffffff;--surface2:#eeede6;--surface3:#e5e4db;
  --border:rgba(0,0,0,0.08);--border2:rgba(0,0,0,0.14);
  --green:#2a6e2a;--green-lt:#e6f2e6;--green-mid:#3d9e3d;
  --blue:#1a5c9e;--blue-lt:#e3eef8;
  --amber:#b06000;--amber-lt:#fdf0df;
  --red:#c0392b;--red-lt:#fde8e6;
  --text:#181818;--text2:#606060;--text3:#a0a0a0;
  --tab-h:62px;--r:14px;--r2:9px;
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow:hidden;-webkit-tap-highlight-color:transparent;-webkit-font-smoothing:antialiased}
#app{display:flex;flex-direction:column;height:100vh;max-width:430px;margin:0 auto;background:var(--bg)}

/* ── HEADER ── */
.hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 18px 10px;background:var(–surface);border-bottom:1px solid var(–border);flex-shrink:0}
.logo{font-family:‘Syne’,sans-serif;font-weight:800;font-size:19px;letter-spacing:-.5px}
.logo em{color:var(–green);font-style:normal}
.hdr-right{display:flex;align-items:center;gap:8px}
.week-pill{font-family:‘DM Mono’,monospace;font-size:10px;background:var(–surface2);border:1px solid var(–border2);border-radius:20px;padding:3px 9px;color:var(–text2)}
.date-lbl{font-family:‘DM Mono’,monospace;font-size:10px;color:var(–text3)}

/* ── PAGES ── */
.pages{flex:1;overflow:hidden;position:relative}
.page{position:absolute;inset:0;overflow-y:auto;padding:14px 16px 24px;display:none;scrollbar-width:none}
.page::-webkit-scrollbar{display:none}
.page.active{display:block}

/* ── TABS ── */
.tabs{height:var(–tab-h);background:var(–surface);border-top:1px solid var(–border);display:flex;align-items:center;padding:0 4px;flex-shrink:0}
.tab{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 2px;border-radius:var(–r2);border:none;background:none;cursor:pointer;transition:background .15s;-webkit-tap-highlight-color:transparent}
.tab:active{background:var(–surface2)}
.tab-icon{font-size:18px;line-height:1}
.tab-lbl{font-size:9.5px;font-weight:500;color:var(–text3);letter-spacing:.2px;transition:color .15s}
.tab.active .tab-lbl{color:var(–green);font-weight:600}
.tab-dot{width:4px;height:4px;border-radius:50%;background:var(–green);opacity:0;transition:opacity .15s;margin-top:-1px}
.tab.active .tab-dot{opacity:1}

/* ── SECTION TITLES ── */
.sec-title{font-family:‘Syne’,sans-serif;font-weight:700;font-size:20px;letter-spacing:-.4px;margin-bottom:4px}
.sec-sub{font-size:12px;color:var(–text2);margin-bottom:16px}

/* ── CARDS ── */
.card{background:var(–surface);border:1px solid var(–border);border-radius:var(–r);padding:14px 16px;margin-bottom:10px}
.card-title{font-family:‘Syne’,sans-serif;font-weight:700;font-size:13px;margin-bottom:12px;color:var(–text)}
.card-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(–border)}
.card-row:last-child{border-bottom:none;padding-bottom:0}
.card-row:first-child{padding-top:0}

/* ── TAGS ── */
.tag{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:20px;font-size:10.5px;font-weight:500;white-space:nowrap}
.tag-green{background:var(–green-lt);color:var(–green)}
.tag-blue{background:var(–blue-lt);color:var(–blue)}
.tag-amber{background:var(–amber-lt);color:var(–amber)}
.tag-red{background:var(–red-lt);color:var(–red)}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:11px 20px;border-radius:var(–r2);border:none;cursor:pointer;font-family:‘DM Sans’,sans-serif;font-size:14px;font-weight:500;transition:all .15s;-webkit-tap-highlight-color:transparent}
.btn-primary{background:var(–green);color:#fff}
.btn-primary:active{background:#1e5a1e}
.btn-ghost{background:var(–surface2);color:var(–text);border:1px solid var(–border2)}
.btn-ghost:active{background:var(–surface3)}
.btn-block{width:100%}
.btn-sm{padding:7px 14px;font-size:12px}

/* ── INPUTS ── */
.inp{width:100%;background:var(–surface2);border:1px solid var(–border2);border-radius:var(–r2);padding:10px 12px;font-family:‘DM Sans’,sans-serif;font-size:14px;color:var(–text);-webkit-appearance:none}
.inp:focus{outline:none;border-color:var(–green-mid)}
.inp-sm{padding:6px 9px;font-size:13px}
.inp-num{width:64px;text-align:center}
.form-row{display:flex;gap:8px;margin-bottom:10px;align-items:flex-end}
.form-group{display:flex;flex-direction:column;gap:5px;flex:1}
.form-lbl{font-size:11px;font-weight:500;color:var(–text2);text-transform:uppercase;letter-spacing:.5px}

/* ── PROGRESS ── */
.prog-bar{height:6px;background:var(–surface2);border-radius:3px;overflow:hidden;margin:6px 0}
.prog-fill{height:100%;border-radius:3px;background:var(–green-mid);transition:width .4s}

/* ── TOAST ── */
#toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(10px);background:#1a1a1a;color:#fff;padding:9px 18px;border-radius:20px;font-size:13px;opacity:0;transition:all .25s;pointer-events:none;z-index:999;white-space:nowrap}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── EMPTY STATE ── */
.empty{text-align:center;padding:40px 20px;color:var(–text3)}
.empty-icon{font-size:36px;margin-bottom:8px}
.empty-txt{font-size:13px}

/* ═══════════════════════════════════════
DASHBOARD
═══════════════════════════════════════ */
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.stat-card{background:var(–surface);border:1px solid var(–border);border-radius:var(–r);padding:13px 14px}
.stat-val{font-family:‘Syne’,sans-serif;font-weight:700;font-size:26px;line-height:1;margin-bottom:3px}
.stat-lbl{font-size:10.5px;color:var(–text2);text-transform:uppercase;letter-spacing:.4px}
.stat-delta{font-size:11px;margin-top:4px}
.delta-good{color:var(–green)}
.delta-bad{color:var(–red)}
.delta-neu{color:var(–text3)}

.phase-banner{background:var(–green);color:#fff;border-radius:var(–r);padding:14px 16px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between}
.phase-name{font-family:‘Syne’,sans-serif;font-weight:700;font-size:15px}
.phase-desc{font-size:11.5px;opacity:.85;margin-top:2px}
.phase-weeks{font-family:‘DM Mono’,monospace;font-size:11px;opacity:.7}

.macro-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.macro-lbl{font-size:12px;color:var(–text2);width:80px;flex-shrink:0}
.macro-val{font-family:‘DM Mono’,monospace;font-size:12px;color:var(–text);width:54px;flex-shrink:0;text-align:right}
.macro-bar-wrap{flex:1;height:5px;background:var(–surface2);border-radius:3px;overflow:hidden}
.macro-fill{height:100%;border-radius:3px}

/* ═══════════════════════════════════════
TREINO
═══════════════════════════════════════ */
.day-tabs{display:flex;gap:6px;margin-bottom:14px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px}
.day-tabs::-webkit-scrollbar{display:none}
.day-tab{flex-shrink:0;padding:7px 14px;border-radius:20px;border:1.5px solid var(–border2);background:none;font-family:‘DM Sans’,sans-serif;font-size:12px;font-weight:500;color:var(–text2);cursor:pointer;transition:all .15s}
.day-tab.active{background:var(–green);border-color:var(–green);color:#fff;font-weight:600}
.day-tab:active{opacity:.7}

.day-focus{font-size:11px;color:var(–green);font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px}

.ex-card{background:var(–surface);border:1px solid var(–border);border-radius:var(–r);margin-bottom:8px;overflow:hidden}
.ex-header{display:flex;align-items:center;justify-content:space-between;padding:11px 14px;cursor:pointer}
.ex-name{font-size:13.5px;font-weight:500}
.ex-meta{font-size:11px;color:var(–text3);margin-top:2px}
.ex-chevron{font-size:12px;color:var(–text3);transition:transform .2s}
.ex-card.open .ex-chevron{transform:rotate(180deg)}
.ex-body{display:none;padding:0 14px 14px;border-top:1px solid var(–border)}
.ex-card.open .ex-body{display:block}
.ex-log-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px}
.ex-log-col{display:flex;flex-direction:column;gap:5px}
.ex-log-lbl{font-size:10px;text-align:center;color:var(–text2);text-transform:uppercase;letter-spacing:.4px}
.ex-log-val{text-align:center;font-family:‘DM Mono’,monospace;font-size:11px;color:var(–text2)}
.note-tag{display:inline-flex;align-items:center;margin-top:8px;font-size:11px;color:var(–text3);background:var(–surface2);padding:4px 8px;border-radius:6px}
.save-ex-btn{width:100%;margin-top:10px}
.pr-badge{display:inline-flex;align-items:center;gap:3px;font-size:10px;background:#fff9e0;color:#8a6000;border:1px solid #f0d060;border-radius:6px;padding:2px 7px;margin-left:6px}

/* ═══════════════════════════════════════
DIETA
═══════════════════════════════════════ */
.diet-day-tabs{display:flex;gap:5px;margin-bottom:14px;overflow-x:auto;scrollbar-width:none}
.diet-day-tabs::-webkit-scrollbar{display:none}
.diet-tab{flex-shrink:0;padding:6px 12px;border-radius:20px;border:1.5px solid var(–border2);background:none;font-family:‘DM Sans’,sans-serif;font-size:11.5px;font-weight:500;color:var(–text2);cursor:pointer}
.diet-tab.active{background:var(–blue);border-color:var(–blue);color:#fff}

.meal-card{background:var(–surface);border:1px solid var(–border);border-radius:var(–r);margin-bottom:8px}
.meal-header{display:flex;align-items:center;gap:10px;padding:12px 14px;cursor:pointer}
.meal-icon{font-size:18px;width:28px;text-align:center}
.meal-info{flex:1}
.meal-name{font-size:13px;font-weight:500}
.meal-time{font-size:10.5px;color:var(–text3);font-family:‘DM Mono’,monospace}
.meal-kcal{font-family:‘DM Mono’,monospace;font-size:12px;color:var(–text2)}
.meal-check{width:20px;height:20px;border-radius:50%;border:2px solid var(–border2);display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.meal-card.done .meal-check{background:var(–green);border-color:var(–green);color:#fff;font-size:10px}
.meal-body{display:none;padding:0 14px 12px;border-top:1px solid var(–border)}
.meal-card.open .meal-body{display:block}
.meal-food{font-size:12.5px;color:var(–text2);line-height:1.6;margin-top:8px}
.meal-macros{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
.macro-chip{font-size:10.5px;padding:2px 8px;border-radius:10px;background:var(–surface2);color:var(–text2)}

.diet-summary{background:var(–green);color:#fff;border-radius:var(–r);padding:13px 16px;margin-bottom:10px}
.diet-sum-title{font-size:11px;opacity:.8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.diet-sum-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.diet-sum-item{text-align:center}
.diet-sum-val{font-family:‘Syne’,sans-serif;font-weight:700;font-size:16px;line-height:1}
.diet-sum-lbl{font-size:9.5px;opacity:.75;margin-top:1px}

/* ═══════════════════════════════════════
SUPLEMENTOS
═══════════════════════════════════════ */
.supp-date-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.supp-date{font-family:‘Syne’,sans-serif;font-weight:700;font-size:17px}
.supp-progress{font-size:12px;color:var(–text2)}

.supp-item{background:var(–surface);border:1px solid var(–border);border-radius:var(–r);padding:13px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:border-color .15s}
.supp-item.taken{border-color:var(–green-mid);background:var(–green-lt)}
.supp-icon{font-size:22px;width:32px;text-align:center;flex-shrink:0}
.supp-info{flex:1}
.supp-name{font-size:13.5px;font-weight:500}
.supp-dose{font-size:11.5px;color:var(–text2);margin-top:2px}
.supp-item.taken .supp-dose{color:var(–green)}
.supp-check{width:24px;height:24px;border-radius:50%;border:2px solid var(–border2);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;transition:all .15s}
.supp-item.taken .supp-check{background:var(–green);border-color:var(–green);color:#fff}
.supp-not-today{opacity:.4;pointer-events:none}
.supp-not-today-lbl{font-size:10px;color:var(–text3);margin-top:2px}

/* ═══════════════════════════════════════
COMPRAS
═══════════════════════════════════════ */
.grocery-header{background:var(–green);color:#fff;border-radius:var(–r);padding:14px 16px;margin-bottom:12px}
.grocery-title{font-family:‘Syne’,sans-serif;font-weight:700;font-size:16px;margin-bottom:2px}
.grocery-sub{font-size:11.5px;opacity:.8}
.grocery-prog{display:flex;align-items:center;gap:8px;margin-top:10px}
.grocery-prog-bar{flex:1;height:5px;background:rgba(255,255,255,0.3);border-radius:3px;overflow:hidden}
.grocery-prog-fill{height:100%;border-radius:3px;background:#fff;transition:width .3s}
.grocery-prog-txt{font-family:‘DM Mono’,monospace;font-size:11px;opacity:.8;white-space:nowrap}

.grocery-warning{background:var(–amber-lt);border:1px solid #e8c080;border-radius:var(–r2);padding:10px 12px;font-size:12px;color:var(–amber);margin-bottom:10px;display:flex;align-items:flex-start;gap:7px}

.cat-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(–text3);margin:14px 0 8px;padding-bottom:5px;border-bottom:1px solid var(–border)}
.cat-label:first-child{margin-top:0}

.g-item{display:flex;align-items:center;gap:10px;background:var(–surface);border:1px solid var(–border);border-radius:var(–r2);padding:10px 12px;margin-bottom:6px;cursor:pointer;transition:all .15s}
.g-item.checked{opacity:.5}
.g-item.checked .g-name{text-decoration:line-through;color:var(–text3)}
.g-check{width:20px;height:20px;border-radius:50%;border:2px solid var(–border2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.g-item.checked .g-check{background:var(–green);border-color:var(–green);color:#fff;font-size:10px}
.g-name{flex:1;font-size:13px}
.g-leftover{font-size:10.5px;background:var(–green-lt);color:var(–green);border-radius:5px;padding:2px 7px;white-space:nowrap}
.g-leftover-btn{font-size:11px;color:var(–text3);padding:2px 6px;background:var(–surface2);border-radius:5px;flex-shrink:0}

.leftover-form{display:flex;gap:6px;padding:6px 12px 10px 42px}
.sync-bar{display:flex;align-items:center;gap:6px;font-size:11px;color:var(–text3);margin-bottom:10px}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(–text3);flex-shrink:0}
.sync-dot.ok{background:var(–green-mid)}
.sync-dot.err{background:var(–red)}
.sync-dot.loading{background:var(–amber);animation:pulse .8s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* ═══════════════════════════════════════
AFAZERES
═══════════════════════════════════════ */
.task-filters{display:flex;gap:5px;margin-bottom:12px;overflow-x:auto;scrollbar-width:none}
.task-filters::-webkit-scrollbar{display:none}
.task-filter{flex-shrink:0;padding:5px 12px;border-radius:20px;border:1.5px solid var(–border2);background:none;font-family:‘DM Sans’,sans-serif;font-size:11.5px;font-weight:500;color:var(–text2);cursor:pointer}
.task-filter.active{background:var(–blue);border-color:var(–blue);color:#fff}
.task-item{background:var(–surface);border:1px solid var(–border);border-radius:var(–r);padding:13px 14px;margin-bottom:8px;display:flex;align-items:flex-start;gap:10px;cursor:pointer;transition:all .15s}
.task-item.done{opacity:.5}
.task-item.done .task-title{text-decoration:line-through;color:var(–text3)}
.task-check{width:20px;height:20px;border-radius:50%;border:2px solid var(–border2);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;transition:all .15s}
.task-item.done .task-check{background:var(–green);border-color:var(–green);color:#fff;font-size:10px}
.task-body{flex:1}
.task-title{font-size:13.5px;font-weight:500;line-height:1.3}
.task-meta{display:flex;align-items:center;gap:6px;margin-top:5px;flex-wrap:wrap}
.task-cat{font-size:10.5px;color:var(–text2);background:var(–surface2);padding:2px 7px;border-radius:5px}
.task-due{font-family:‘DM Mono’,monospace;font-size:10px;color:var(–text3)}
.task-due.overdue{color:var(–red)}
.task-notes{font-size:11.5px;color:var(–text2);margin-top:4px;line-height:1.4}
.task-add-btn{position:fixed;bottom:calc(var(–tab-h) + 16px);right:16px;width:48px;height:48px;border-radius:50%;background:var(–blue);color:#fff;border:none;font-size:24px;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 16px rgba(26,92,158,.35);z-index:50}
.pri-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:6px}
.pri-alta{background:var(–red)}
.pri-media{background:var(–amber)}
.pri-baixa{background:var(–green-mid)}

/* ═══════════════════════════════════════
EVOLUÇÃO
═══════════════════════════════════════ */
.chart-wrap{background:var(–surface);border:1px solid var(–border);border-radius:var(–r);padding:14px;margin-bottom:10px}
.chart-title{font-size:12px;font-weight:600;color:var(–text2);margin-bottom:10px;text-transform:uppercase;letter-spacing:.4px}
canvas{width:100%;display:block}

.hist-row{display:flex;align-items:center;padding:9px 0;border-bottom:1px solid var(–border);gap:10px}
.hist-week{font-family:‘DM Mono’,monospace;font-size:11px;color:var(–text3);width:30px;flex-shrink:0}
.hist-date{font-size:11.5px;color:var(–text2);flex:1}
.hist-vals{display:flex;gap:10px}
.hist-val{font-family:‘DM Mono’,monospace;font-size:12px;color:var(–text)}
.hist-delta{font-size:11px}

/* ═══════════════════════════════════════
REGISTRO SEMANAL MODAL
═══════════════════════════════════════ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;display:flex;align-items:flex-end;opacity:0;pointer-events:none;transition:opacity .2s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal-sheet{background:var(–surface);border-radius:20px 20px 0 0;width:100%;max-width:430px;margin:0 auto;padding:20px 18px 32px;transform:translateY(100%);transition:transform .25s}
.modal-overlay.open .modal-sheet{transform:translateY(0)}
.modal-handle{width:36px;height:4px;background:var(–border2);border-radius:2px;margin:0 auto 18px}
.modal-title{font-family:‘Syne’,sans-serif;font-weight:700;font-size:17px;margin-bottom:16px}
</style>

</head>
