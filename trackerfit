let groceryCache = {}; // item -> {id, checked, leftover}
let ameixaAdded = load('tf_ameixa', false);

async function loadGrocery() {
  setSyncStatus('grocery-sync-dot','grocery-sync-txt','loading','Sincronizando...');
  const rows = await sb.get('grocery_list', `week=eq.${currentWeek}&select=*`);
  if(rows === null) {
    setSyncStatus('grocery-sync-dot','grocery-sync-txt','err','Sem conexão — dados locais');
    return;
  }
  groceryCache = {};
  rows.forEach(r => { groceryCache[r.item] = {id:r.id, checked:r.checked, leftover:r.leftover||''}; });
  setSyncStatus('grocery-sync-dot','grocery-sync-txt','ok','Sincronizado');
  renderGrocery();
}

function renderGrocery() {
  const allItems = getAllGroceryItems();
  const checkedCount = allItems.filter(i=>groceryCache[i]?.checked).length;
  const pct = allItems.length ? Math.round(checkedCount/allItems.length*100) : 0;

  document.getElementById('grocery-sub').textContent = `Semana ${currentWeek} · ${new Date().toLocaleDateString('pt-BR',{day:'2-digit',month:'short'})}`;
  document.getElementById('grocery-prog-fill').style.width = pct+'%';
  document.getElementById('grocery-prog-txt').textContent = pct+'%';
  document.getElementById('ameixa-warning').style.display = ameixaAdded ? 'none' : 'flex';

  const c = document.getElementById('grocery-list');
  c.innerHTML = '';
  const cats = {...GROCERY_CATS};
  if(ameixaAdded) cats['🍎 Frutas'] = [...cats['🍎 Frutas'], 'Ameixa ⚠️'];

  Object.entries(cats).forEach(([cat, items]) => {
    const lbl = document.createElement('div');
    lbl.className = 'cat-label';
    lbl.textContent = cat;
    c.appendChild(lbl);

    items.forEach(item => {
      const d = groceryCache[item] || {};
      const isChecked = !!d.checked;
      const leftover = d.leftover || '';
      const safeId = item.replace(/[^a-zA-Z0-9]/g,'_');

      const wrap = document.createElement('div');
      const row = document.createElement('div');
      row.className = 'g-item'+(isChecked?' checked':'');
      row.innerHTML = `
        <div class="g-check">${isChecked?'✓':''}</div>
        <span class="g-name">${item}</span>
        ${leftover?`<span class="g-leftover">sobra: ${leftover}</span>`:''}
        <span class="g-leftover-btn" onclick="openLeftover(event,'${safeId}')">
          ${leftover?'✏️':'+ sobra'}
        </span>`;
      row.addEventListener('click', e => {
        if(!e.target.classList.contains('g-leftover-btn') && !e.target.closest('.leftover-form'))
          toggleGrocery(item);
      });
      wrap.appendChild(row);

      const form = document.createElement('div');
      form.className = 'leftover-form';
      form.id = 'lf-'+safeId;
      form.style.display = 'none';
      form.innerHTML = `<input class="inp inp-sm" style="flex:1" placeholder="ex: metade do mamão" value="${leftover}">
        <button class="btn btn-primary btn-sm" onclick="saveLeftover('${item}',this)">OK</button>`;
      wrap.appendChild(form);
      c.appendChild(wrap);
    });
  });
}

function buildGrocery() { loadGrocery(); }

function getAllGroceryItems() {
  const all = Object.values(GROCERY_CATS).flat();
  if(ameixaAdded) all.push('Ameixa ⚠️');
  return all;
}

async function toggleGrocery(item) {
  const d = groceryCache[item] || {};
  const newVal = !d.checked;
  // Optimistic UI
  groceryCache[item] = {...d, checked:newVal};
  renderGrocery();

  if(d.id) {
    await sb.patch('grocery_list', {checked:newVal, updated_at: new Date().toISOString()}, `id=eq.${d.id}`);
  } else {
    const res = await sb.post('grocery_list', {week:currentWeek, item, checked:newVal, category:getCatForItem(item)});
    if(res && res[0]) groceryCache[item].id = res[0].id;
  }
  setSyncStatus('grocery-sync-dot','grocery-sync-txt','ok','Salvo ✓');
}

function openLeftover(e, safeId) {
  e.stopPropagation();
  const form = document.getElementById('lf-'+safeId);
  if(!form) return;
  const isOpen = form.style.display !== 'none';
  document.querySelectorAll('.leftover-form').forEach(f=>f.style.display='none');
  if(!isOpen) form.style.display = 'flex';
}

async function saveLeftover(item, btn) {
  const form = btn.closest('.leftover-form');
  const val = form.querySelector('input').value.trim();
  const d = groceryCache[item] || {};
  groceryCache[item] = {...d, leftover:val};
  form.style.display = 'none';
  renderGrocery();

  if(d.id) {
    await sb.patch('grocery_list', {leftover:val, updated_at:new Date().toISOString()}, `id=eq.${d.id}`);
  } else {
    const res = await sb.post('grocery_list', {week:currentWeek, item, leftover:val, checked:false, category:getCatForItem(item)});
    if(res && res[0]) groceryCache[item].id = res[0].id;
  }
  showToast('Sobra salva: '+val);
  setSyncStatus('grocery-sync-dot','grocery-sync-txt','ok','Salvo ✓');
}

async function addAmeixa() {
  ameixaAdded = true;
  save('tf_ameixa', true);
  renderGrocery();
  showToast('Ameixa adicionada à lista');
}

function getCatForItem(item) {
  for(const [cat,items] of Object.entries(GROCERY_CATS)) {
    if(items.includes(item)) return cat;
  }
  return 'Outros';
}

