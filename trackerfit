// EVOLUÇÃO
// ══════════════════════════════════════════════════════════════
function buildEvolucao() {
  const c = document.getElementById('hist-list');
  c.innerHTML = '';

  if(!weeklyData.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">📊</div><div class="empty-txt">Nenhum dado registrado ainda.<br>Use o botão "Registrar semana" no Dashboard.</div></div>';
    drawChart('chart-peso', [], 'peso', 'kg');
    drawChart('chart-cintura', [], 'cintura', 'cm');
    return;
  }

  [...weeklyData].reverse().forEach((w,i)=>{
    const prev = weeklyData[weeklyData.length-2-i];
    const row = document.createElement('div');
    row.className = 'hist-row';
    row.innerHTML = `
      <span class="hist-week">S${w.semana}</span>
      <span class="hist-date">${w.data||'–'}</span>
      <div class="hist-vals">
        <span class="hist-val">${w.peso?w.peso+'kg':'–'}</span>
        <span class="hist-val">${w.cintura?w.cintura+'cm':'–'}</span>
        <span class="hist-val">${w.treinos??'–'}/5</span>
        ${prev&&w.peso&&prev.peso?`<span class="hist-delta ${w.peso<prev.peso?'delta-good':'delta-bad'}">${w.peso<prev.peso?'↓':'↑'}${Math.abs(w.peso-prev.peso).toFixed(1)}</span>`:''}
      </div>`;
    c.appendChild(row);
  });

  drawChart('chart-peso', weeklyData, 'peso', 'kg');
  drawChart('chart-cintura', weeklyData, 'cintura', 'cm');
}

function drawChart(id, data, key, unit) {
  const canvas = document.getElementById(id);
  if(!canvas) return;
  const dpr = window.devicePixelRatio||1;
  const W = canvas.offsetWidth||300, H = parseInt(canvas.getAttribute('height'))||100;
  canvas.width = W*dpr; canvas.height = H*dpr;
  canvas.style.width = W+'px'; canvas.style.height = H+'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr,dpr);

  const pts = data.filter(d=>d[key]).map((d,i)=>({x:i,y:parseFloat(d[key]),lbl:'S'+d.semana}));
  if(pts.length<2){
    ctx.fillStyle='#aaa'; ctx.font='12px DM Sans,sans-serif';
    ctx.textAlign='center'; ctx.fillText('Dados insuficientes para gráfico',W/2,H/2);
    return;
  }

  const padL=36,padR=12,padT=10,padB=22;
  const minV=Math.min(...pts.map(p=>p.y))-1;
  const maxV=Math.max(...pts.map(p=>p.y))+1;
  const scX=i=>(W-padL-padR)/(pts.length-1)*i+padL;
  const scY=v=>padT+(1-(v-minV)/(maxV-minV))*(H-padT-padB);

  // Grid
  ctx.strokeStyle='rgba(0,0,0,.05)'; ctx.lineWidth=1;
  [0,.5,1].forEach(r=>{
    const y=padT+r*(H-padT-padB);
    ctx.beginPath(); ctx.moveTo(padL,y); ctx.lineTo(W-padR,y); ctx.stroke();
    ctx.fillStyle='#a0a0a0'; ctx.font='9px DM Mono,monospace'; ctx.textAlign='right';
    ctx.fillText((minV+(maxV-minV)*(1-r)).toFixed(1),padL-4,y+3);
  });

  // Line
  ctx.beginPath(); ctx.moveTo(scX(0),scY(pts[0].y));
  pts.forEach((p,i)=>{ if(i>0) ctx.lineTo(scX(i),scY(p.y)); });
  ctx.strokeStyle='#2a6e2a'; ctx.lineWidth=2.5; ctx.lineJoin='round'; ctx.stroke();

  // Fill
  ctx.beginPath(); ctx.moveTo(scX(0),scY(pts[0].y));
  pts.forEach((p,i)=>{ if(i>0) ctx.lineTo(scX(i),scY(p.y)); });
  ctx.lineTo(scX(pts.length-1),H-padB); ctx.lineTo(scX(0),H-padB); ctx.closePath();
  ctx.fillStyle='rgba(42,110,42,.08)'; ctx.fill();

  // Dots
  pts.forEach((p,i)=>{
    ctx.beginPath(); ctx.arc(scX(i),scY(p.y),3.5,0,Math.PI*2);
    ctx.fillStyle='#2a6e2a'; ctx.fill();
  });

  // X labels
  ctx.fillStyle='#a0a0a0'; ctx.font='9px DM Mono,monospace'; ctx.textAlign='center';
  pts.forEach((p,i)=>{ if(i===0||i===pts.length-1||pts.length<=6) ctx.fillText(p.lbl,scX(i),H-padB+13); });
}

