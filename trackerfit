function buildSupplements() {
  const today = todayKey();
  const dow = DOW[new Date().getDay()];
  const taken = suppLogs[today] || {};

  const todaySupps = SUPPS.filter(s => s.days==='all' || s.days.includes(dow));
  const allSupps = SUPPS;
  const takenCount = todaySupps.filter(s=>taken[s.id]).length;

  const dateEl = document.getElementById('supp-date-lbl');
  dateEl.textContent = new Date().toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long'});
  document.getElementById('supp-progress').textContent = takenCount+'/'+todaySupps.length+' tomados';
  document.getElementById('supp-prog-fill').style.width = (todaySupps.length?Math.round(takenCount/todaySupps.length*100):0)+'%';

  const c = document.getElementById('supp-list');
  c.innerHTML = '';

  allSupps.forEach(s => {
    const isToday = s.days==='all' || s.days.includes(dow);
    const isTaken = !!taken[s.id];
    const div = document.createElement('div');
    div.className = 'supp-item'+(isTaken?' taken':'')+(isToday?'':' supp-not-today');
    div.onclick = isToday ? ()=>toggleSupp(s.id) : null;
    div.innerHTML = `
      <span class="supp-icon">${s.icon}</span>
      <div class="supp-info">
        <div class="supp-name">${s.name}</div>
        <div class="supp-dose">${isTaken?'✓ tomado — ':''}${s.dose}</div>
        ${!isToday?'<div class="supp-not-today-lbl">Não programado para hoje</div>':'<div class="supp-dose" style="font-size:10.5px;color:var(--text3)">${s.when}</div>'}
      </div>
      <div class="supp-check">${isTaken?'✓':''}</div>`;
    // Fix the when label since template literal inside template literal needs escaping
    const doseDiv = div.querySelectorAll('.supp-dose');
    if(doseDiv.length>1) doseDiv[1].textContent = s.when;
    c.appendChild(div);
  });
}

function toggleSupp(id) {
  const today = todayKey();
  if (!suppLogs[today]) suppLogs[today] = {};
  suppLogs[today][id] = !suppLogs[today][id];
  save('tf_suppl', suppLogs);
  buildSupplements();
  const s = SUPPS.find(x=>x.id===id);
  if(suppLogs[today][id]) showToast(s.icon+' '+s.name+' registrado');
}

