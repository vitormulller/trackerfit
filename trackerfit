  document.getElementById('m-cintura').value = existing.cintura||'';
  document.getElementById('m-treinos').value = existing.treinos||'';
  document.getElementById('m-cardio').value = existing.cardio||'';
  document.getElementById('m-sono').value = existing.sono||'';
  document.getElementById('m-energia').value = existing.energia||'';
  document.getElementById('m-obs').value = existing.obs||'';
  document.getElementById('modal').classList.add('open');
}

function closeModal(e) {
  if(!e || e.target.id==='modal' || e.currentTarget.tagName==='BUTTON') {
    document.getElementById('modal').classList.remove('open');
  }
}

function saveWeek() {
  const entry = {
    semana: currentWeek,
    data: new Date().toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric'}),
    peso: parseFloat(document.getElementById('m-peso').value)||null,
    cintura: parseFloat(document.getElementById('m-cintura').value)||null,
    treinos: parseInt(document.getElementById('m-treinos').value)||null,
    cardio: parseInt(document.getElementById('m-cardio').value)||null,
    sono: parseFloat(document.getElementById('m-sono').value)||null,
    energia: parseInt(document.getElementById('m-energia').value)||null,
    obs: document.getElementById('m-obs').value,
  };
  const idx = weeklyData.findIndex(w=>w.semana===currentWeek);
  if(idx>=0) weeklyData[idx]=entry; else weeklyData.push(entry);
  weeklyData.sort((a,b)=>a.semana-b.semana);
  save('tf_weekly', weeklyData);
  closeModal();
  buildDashboard();
  showToast('✅ Semana '+currentWeek+' salva!');
}

