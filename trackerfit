function buildExercises() {
  const day = WORKOUT[currentDay];
  document.getElementById('day-focus').textContent = '🎯 '+day.focus;
  const c = document.getElementById('ex-list');
  c.innerHTML = '';
  const logs = workoutLogs[todayKey()] || {};

  day.exercises.forEach(ex => {
    const key = currentDay+'_'+ex.name;
    const saved = logs[key] || {};
    const pr = getPR(ex.name, saved.load);

    const card = document.createElement('div');
    card.className = 'ex-card';
    card.innerHTML = `
      <div class="ex-header" onclick="toggleEx(this)">
        <div>
          <div class="ex-name">${ex.name}${pr?' <span class="pr-badge">🏆 PR</span>':''}</div>
          <div class="ex-meta">${ex.sets} séries × ${ex.reps} reps · descanso ${ex.rest}</div>
        </div>
        <span class="ex-chevron">▼</span>
      </div>
      <div class="ex-body">
        <span class="note-tag">💡 ${ex.note}</span>
        <div class="ex-log-grid">
          <div class="ex-log-col">
            <span class="ex-log-lbl">Carga (kg)</span>
            <input class="inp inp-sm inp-num" id="inp-load-${key}" type="number" step="2.5" placeholder="–" value="${saved.load||''}">
            <span class="ex-log-val" id="pr-val-${key}">${getBestLoad(ex.name) ? 'Melhor: '+getBestLoad(ex.name)+'kg' : 'Sem registro'}</span>
          </div>
          <div class="ex-log-col">
            <span class="ex-log-lbl">Reps feitas</span>
            <input class="inp inp-sm inp-num" id="inp-reps-${key}" type="number" placeholder="${ex.reps}" value="${saved.repsActual||''}">
            <span class="ex-log-val">Meta: ${ex.reps}</span>
          </div>
          <div class="ex-log-col">
            <span class="ex-log-lbl">Séries ok</span>
            <input class="inp inp-sm inp-num" id="inp-sets-${key}" type="number" min="0" max="${ex.sets}" placeholder="${ex.sets}" value="${saved.setsActual||''}">
            <span class="ex-log-val">Meta: ${ex.sets}</span>
          </div>
        </div>
        <button class="btn btn-ghost btn-sm save-ex-btn" onclick="saveExercise('${key}','${ex.name}')">Salvar exercício</button>
      </div>`;
    c.appendChild(card);
  });
}

function toggleEx(header) {
  const card = header.closest('.ex-card');
  card.classList.toggle('open');
}

function saveExercise(key, exName) {
  const load = document.getElementById('inp-load-'+key)?.value;
  const repsActual = document.getElementById('inp-reps-'+key)?.value;
  const setsActual = document.getElementById('inp-sets-'+key)?.value;

  const today = todayKey();
  if (!workoutLogs[today]) workoutLogs[today] = {};
  workoutLogs[today][key] = { load: parseFloat(load)||null, repsActual, setsActual, ts: Date.now() };

  // Update PR store
  if (load) {
    const prs = load('tf_prs', {});
    if (!prs[exName] || parseFloat(load) > prs[exName]) {
      const all = load('tf_prs', {});
      all[exName] = parseFloat(load);
      save('tf_prs', all);
    }
  }

  save('tf_workout', workoutLogs);
  showToast('💪 '+exName+' salvo!');
  buildExercises();
}

function getPR(exName, currentLoad) {
  if (!currentLoad) return false;
  const prs = load('tf_prs', {});
  const best = prs[exName];
  return best && parseFloat(currentLoad) > best;
}

function getBestLoad(exName) {
  const prs = load('tf_prs', {});
  return prs[exName] || null;
}

