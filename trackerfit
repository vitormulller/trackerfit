function buildDayTabs() {
  const c = document.getElementById('day-tabs');
  c.innerHTML = '';
  DAYS.forEach(d => {
    const b = document.createElement('button');
    b.className = 'day-tab'+(d===currentDay?' active':'');
    b.textContent = d;
    b.onclick = () => { currentDay=d; buildDayTabs(); buildExercises(); };
