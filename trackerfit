function buildDietTabs() {
  const isWeekend = [0,6].includes(new Date().getDay());
  currentDietDay = isWeekend ? 1 : 0;
  const wrap = document.createElement('div');
  wrap.className = 'diet-day-tabs';
  ['Seg–Sex','Sáb–Dom'].forEach((lbl,i)=>{
    const b = document.createElement('button');
    b.className='diet-tab'+(currentDietDay===i?' active':'');
    b.textContent=lbl;
    b.onclick=()=>{ currentDietDay=i; document.querySelectorAll('.diet-tab').forEach((t,j)=>t.classList.toggle('active',j===i)); buildMeals(); };
    wrap.appendChild(b);
  });
  const page = document.getElementById('page-dieta');
  const existing = page.querySelector('.diet-day-tabs');
  if(existing) existing.replaceWith(wrap); else page.insertBefore(wrap, document.getElementById('diet-summary'));
